---
import { Heading, PreviewCard, Socials, Stack } from '@halyard/ui'
import Layout from '../layouts/Layout.astro'
---

<Layout title="Alex Hinds, engineer and product leader" description="">
  <Stack gap="gap-24">
    <Stack gap="gap-8" className="splash">
      <Heading className="heading-xl" as="h1">
        <span class="text-brand-bold">Alex Hinds</span> is building something new.
        I'm based in Sydney.
      </Heading>
      <Stack gap="gap-4">
        <p>
          I'm building{' '}
          <a href="https://usehalyard.ai">Halyard</a>, an AI context platform
          that helps teams capture and share expertise. I also consult and
          advise through{' '}
          <a href="https://halyard.studio">Halyard Studio</a>{' '}
          on AI product strategy, engineering leadership and design systems.
          Previously I led product and engineering at{' '}
          <a href="https://lorikeetcx.ai">Lorikeet</a>{' '}
          from pre-revenue to Series B, and built{' '}
          <a href="https://atlassian.design">design systems at Atlassian</a>.
        </p>
        <Socials />
      </Stack>
    </Stack>
    <div class="grid sm:grid-cols-2 gap-8 -m-8 p-8 bg-accent">
      <Heading className="heading-300 col-span-1 sm:col-span-2" as="h2">
        Featured
      </Heading>
      <PreviewCard
        heading="One person, many frameworks"
        href="/posts"
        published={{
          iso: new Date().toISOString(),
          formatted: 'Pinned',
        }}
        promoLink
      >
        This site was built with{' '}
        <a href="https://astro.build/">Astro</a>. This site has also been <a
          href="https://alhinds.com">deployed</a
        > and built with <a href="https://nextjs.org/">Next.js</a>. My old
        website{' '}
        <a href="https://vue2.alhinds.com">lives here</a>.
      </PreviewCard>
    </div>
  </Stack>
</Layout>
